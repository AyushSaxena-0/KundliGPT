# =========================================================================
#                   AI VEDIC ASTROLOGER - ENVIRONMENT VARIABLES TEMPLATE
# =========================================================================

# ----------------- BACKEND (FastAPI) CONFIGURATIONS -----------------
# Get your key from Google AI Studio (https://aistudio.google.com/)
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# CORS origins (comma-separated URLs, no trailing slashes)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.pages.dev

# Run environment (development / production)
ENVIRONMENT=production

# Set to false in production to disable verbose tracebacks
DEBUG=false

# Application metadata
APP_NAME="AI Vedic Astrologer"
BACKEND_URL=https://your-backend-service.onrender.com


# ----------------- FRONTEND (Next.js) CONFIGURATIONS -----------------
# Public URL of the FastAPI backend for client-side API requests
NEXT_PUBLIC_BACKEND_URL=https://your-backend-service.onrender.com
